# --- World ID 4.0 (REQUIRED) ---
# 1. Create an app at https://developer.world.org/
# 2. Enable World ID 4.0 (banner on the app page) and complete RP registration.
# 3. Add an Action with identifier "verify-human" (or change VITE_WORLD_ACTION).
# 4. Copy the app id, the RP id, and the signing key.
#    - app id and RP id go in the Vercel/.env.local frontend config (below).
#    - signing key is a SERVER SECRET and goes only into Supabase function
#      secrets (`WORLD_SIGNING_KEY`). Never expose it to the client.
VITE_WORLD_APP_ID=app_REPLACE_ME
VITE_WORLD_RP_ID=rp_REPLACE_ME
VITE_WORLD_ACTION=verify-human

# Accept legacy World ID 3.0 proofs alongside 4.0. Recommended during the v4
# rollout because most existing users still have 3.0 credentials.
VITE_WORLD_ALLOW_LEGACY_PROOFS=true

# --- Supabase (REQUIRED) ---
# 1. Create a project at https://supabase.com/dashboard
# 2. Open: Project Settings -> API
# 3. Copy the Project URL and the "anon public" key below.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...REPLACE_ME

# --- Edge Functions ---
# Two Supabase Edge Functions back the verification flow:
#
#   rp-sign          — signs RP requests with WORLD_SIGNING_KEY (server secret)
#   verify-world-id  — proxies POST https://developer.world.org/api/v4/verify/{rp_id}
#
# Deploy both, then set their secrets:
#   supabase secrets set WORLD_RP_ID=rp_xxxxxxxx
#   supabase secrets set WORLD_SIGNING_KEY=0xYOUR_RP_SIGNING_KEY
#   supabase secrets set WORLD_ACTION=verify-human
#   supabase functions deploy rp-sign --no-verify-jwt
#   supabase functions deploy verify-world-id --no-verify-jwt
#
# Only override these if you deployed under different names:
# VITE_RP_SIGN_FUNCTION_NAME=rp-sign
# VITE_VERIFY_FUNCTION_NAME=verify-world-id

# --- DEV ONLY ---
# Bypasses World ID with a deterministic mock human. NEVER set true in prod.
VITE_ALLOW_MOCK_VERIFY=false
