# --- World ID (REQUIRED) ---
# 1. Create an app at https://developer.worldcoin.org/
# 2. Set verification level to Orb
# 3. Add an Action with identifier "verify-human" (or change VITE_WORLD_ACTION)
# 4. Paste your app id below.
VITE_WORLD_APP_ID=app_staging_REPLACE_ME
VITE_WORLD_ACTION=verify-human

# --- Supabase (REQUIRED) ---
# 1. Create a project at https://supabase.com/dashboard
# 2. Open: Project Settings -> API
# 3. Copy the Project URL and the "anon public" key below.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...REPLACE_ME

# --- verify-world-id Edge Function ---
# The browser POSTs the World ID proof to this Supabase Edge Function, which
# forwards it server-side to developer.worldcoin.org/api/v2/verify (the
# Worldcoin endpoint does not allow browser CORS calls).
#
# Deploy it once:
#   supabase secrets set WORLD_APP_ID=app_xxxxxxxx WORLD_ACTION=verify-human
#   supabase functions deploy verify-world-id --no-verify-jwt
#
# Override only if you renamed the function during deploy.
# VITE_VERIFY_FUNCTION_NAME=verify-world-id

# --- DEV ONLY ---
# Bypasses World ID with a deterministic mock human. NEVER set true in prod.
VITE_ALLOW_MOCK_VERIFY=false
